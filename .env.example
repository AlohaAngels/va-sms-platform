# ============================================
# Visiting Angels AI SMS Platform v2.1
# All Environment Variables
# ============================================

# Twilio (from twilio.com/console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+12085551234

# Anthropic API (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Server
NODE_ENV=production

# Team Notifications (comma-separated phone numbers)
COORDINATOR_PHONE=+12085551111,+12085552222,+12085553333

# HubSpot CRM (from HubSpot > Settings > Private Apps)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Resend Email Service (from resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Email Settings
EMAIL_FROM_ADDRESS=care@boiseidahohomecare.com

# Weekly Report Recipients (comma-separated emails)
REPORT_EMAIL_TO=matt@example.com,coordinator@example.com

# Google Calendar (OAuth2)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=boiseidahohomecare.com_xxxxx@group.calendar.google.com

# Lily (HR) — Caregiver Recruitment
TWILIO_HR_PHONE_NUMBER=+12083306766
MEGAN_CALENDAR_ID=mdickson@boiseidahohomecare.com
